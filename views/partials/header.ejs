<header class="site-header" id="top">
  <div class="container nav-bar">
    <a href="/" class="brand" aria-label="<%= site.brand %> home">
      <img src="/img/logo/backlinkedge-logo.png" alt="<%= site.brand %>" class="brand-logo" />
    </a>

    <nav class="main-nav" id="main-nav" aria-label="Primary">
      <%
        const cp = (typeof currentPath !== 'undefined' && currentPath) ? currentPath : '/';
        function navActive(href) {
          if (href === '/blog') return cp.indexOf('/blog') === 0;
          if (href === '/') return cp === '/';
          return false; // hash links are handled by the scrollspy on the home page
        }
        function sectionId(href) {
          const i = href.indexOf('#');
          return i === -1 ? '' : href.slice(i + 1);
        }
      %>
      <% site.nav.forEach(function(item){ %>
        <% if (item.dropdown === 'services' && typeof services !== 'undefined' && services.length) { %>
          <div class="nav-item has-dropdown">
            <a href="<%= item.href %>"
               class="nav-link<%= navActive(item.href) ? ' is-active' : '' %>"
               <% if (sectionId(item.href)) { %>data-section="<%= sectionId(item.href) %>"<% } %>
               aria-haspopup="true">
              <%= item.label %>
              <svg class="caret" viewBox="0 0 24 24" width="14" height="14" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="dropdown-menu" role="menu">
              <% services.forEach(function(s){ %>
                <a href="/services/<%= s.slug %>" class="dropdown-link" role="menuitem">
                  <span class="dropdown-icon" style="--c:<%= s.color %>"><%- include('icon', { name: s.icon }) %></span>
                  <span class="dropdown-text">
                    <strong><%= s.name %></strong>
                    <small><%= s.tagline %></small>
                  </span>
                </a>
              <% }); %>
            </div>
          </div>
        <% } else { %>
          <a href="<%= item.href %>"
             class="nav-link<%= navActive(item.href) ? ' is-active' : '' %>"
             <% if (sectionId(item.href)) { %>data-section="<%= sectionId(item.href) %>"<% } %>><%= item.label %></a>
        <% } %>
      <% }); %>
    </nav>

    <div class="nav-actions">
      <a href="#contact" class="btn btn-primary btn-sm">Get Free SEO Audit</a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
