<%# Renders JSON-LD structured data. Expects `schemas` (array of objects). %>
<% if (typeof schemas !== 'undefined' && Array.isArray(schemas)) { %>
  <% schemas.forEach(function (s) { %>
<script type="application/ld+json">
<%- JSON.stringify(s, null, 2).replace(/<\//g, '<\\/') %>
</script>
  <% }) %>
<% } %>
