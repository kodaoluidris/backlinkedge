<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <!-- ============ HERO ============ -->
    <section class="svc-hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container svc-hero-grid">
        <div class="svc-hero-copy">
          <% if (service.eyebrow) { %>
            <span class="svc-eyebrow" style="--c:<%= service.color %>"><%= service.eyebrow %></span>
          <% } else { %>
            <nav class="crumbs" aria-label="Breadcrumb">
              <a href="/">Home</a><span>/</span><a href="/#services">Services</a><span>/</span><strong><%= service.name %></strong>
            </nav>
          <% } %>
          <h1 class="svc-hero-title">
            <%= service.heading || service.name %>
            <% if (service.headingAccent) { %><span class="accent"><%= service.headingAccent %></span><% } %>
          </h1>
          <% if (service.subheading) { %><p class="svc-hero-sub"><%= service.subheading %></p><% } %>
          <% var introArr = Array.isArray(service.intro) ? service.intro : (service.intro ? [service.intro] : []); %>
          <% introArr.slice(0,2).forEach(function(p){ %><p class="svc-hero-lead"><%= p %></p><% }); %>

          <% if (service.heroFeatures && service.heroFeatures.length) { %>
            <ul class="hero-features-row">
              <% service.heroFeatures.forEach(function(f){ %>
                <li><span class="hf-ico" style="--c:<%= service.color %>"><%- include('partials/icon', { name: f.icon || 'check' }) %></span><span><%= f.label %></span></li>
              <% }); %>
            </ul>
          <% } else if (service.heroPoints && service.heroPoints.length) { %>
            <ul class="hero-points">
              <% service.heroPoints.forEach(function(p){ %>
                <li><span class="hp-check" style="--c:<%= service.color %>"><%- include('partials/icon', { name: 'check' }) %></span>
                  <span class="hp-text"><strong><%= p[0] %></strong><small><%= p[1] %></small></span></li>
              <% }); %>
            </ul>
          <% } %>

          <div class="svc-hero-cta">
            <a href="<%= (service.ctaPrimary && service.ctaPrimary.href) || '/#contact' %>" class="btn btn-primary"><%= (service.ctaPrimary && service.ctaPrimary.label) || 'Get Free SEO Audit' %> <%- include('partials/icon', { name: 'arrow' }) %></a>
            <a href="<%= (service.ctaSecondary && service.ctaSecondary.href) || '#offerings' %>" class="btn btn-outline"><%= (service.ctaSecondary && service.ctaSecondary.label) || 'View Our Services' %></a>
          </div>
        </div>

        <!-- Illustration -->
        <div class="svc-hero-visual" aria-hidden="true">
          <% if (service.heroVisual === 'map-pack') { %>
            <span class="svc-hero-mark map" style="--c:<%= service.color %>"><%- include('partials/icon', { name: 'pin' }) %></span>
            <div class="viz-map">
              <div class="viz-map-canvas">
                <span class="map-pin p1"><%- include('partials/icon', { name: 'pin' }) %></span>
                <span class="map-pin p2"><%- include('partials/icon', { name: 'pin' }) %></span>
                <span class="map-pin p3 is-main"><%- include('partials/icon', { name: 'pin' }) %></span>
              </div>
            </div>
            <div class="viz-card viz-badge">
              <div class="viz-head"><span>Map Pack Rankings</span></div>
              <strong class="viz-badge-num up">▲ +142%</strong>
              <span class="viz-badge-sub">in 90 Days</span>
            </div>

          <% } else if (service.heroVisual === 'content') { %>
            <span class="svc-hero-mark target" style="--c:<%= service.color %>"><%- include('partials/icon', { name: 'target' }) %></span>
            <div class="viz-card viz-blog">
              <span class="viz-blog-label">BLOG POST</span>
              <div class="viz-blog-img"><%- include('partials/icon', { name: 'content' }) %></div>
              <div class="viz-blog-lines"><i></i><i></i><i></i><i class="short"></i></div>
            </div>
            <div class="viz-card viz-mini viz-mini-1">
              <span class="viz-mini-label">Google Rankings</span>
              <strong class="up">▲ +145%</strong>
              <span class="viz-mini-sub">in 90 Days</span>
            </div>
            <div class="viz-card viz-mini viz-mini-2">
              <span class="viz-mini-label">Organic Traffic</span>
              <strong class="up">▲ +178%</strong>
              <span class="viz-mini-sub">in 90 Days</span>
            </div>

          <% } else if (service.heroVisual === 'site-health') { %>
            <div class="viz-card viz-health">
              <span class="viz-health-label">SITE HEALTH</span>
              <div class="viz-gauge-lg"><span class="vgl-ring"></span><span class="vgl-num"><strong>95</strong><small>/100</small></span></div>
              <ul class="viz-check">
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Crawling</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Indexing</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Performance</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Mobile Friendly</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Security</li>
              </ul>
            </div>
            <div class="viz-card viz-mini viz-pagespeed">
              <span class="viz-mini-label">PageSpeed Insights</span>
              <strong class="up">96</strong>
              <span class="viz-mini-sub">Performance Score</span>
            </div>

          <% } else if (service.heroVisual === 'consulting') { %>
            <span class="svc-hero-mark target" style="--c:<%= service.color %>"><%- include('partials/icon', { name: 'target' }) %></span>
            <div class="viz-card viz-traffic">
              <span class="viz-dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <div class="viz-head"><span>SEO Performance Overview</span><strong class="up">▲ +152%</strong></div>
              <svg viewBox="0 0 320 100" preserveAspectRatio="none" class="viz-chart">
                <defs><linearGradient id="vgc" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#16b981" stop-opacity="0.30"/><stop offset="100%" stop-color="#16b981" stop-opacity="0"/></linearGradient></defs>
                <path d="M0,88 C42,84 58,66 92,68 C128,70 144,46 184,46 C220,46 250,26 286,18 C302,15 312,11 320,7 L320,100 L0,100 Z" fill="url(#vgc)"/>
                <path d="M0,88 C42,84 58,66 92,68 C128,70 144,46 184,46 C220,46 250,26 286,18 C302,15 312,11 320,7" fill="none" stroke="#16b981" stroke-width="2.5" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="viz-card viz-roadmap">
              <span class="viz-health-label">SEO Strategy Roadmap</span>
              <ul class="viz-check">
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>SEO Audit</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Content Strategy</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Keyword Targeting</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>On-Page SEO</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Link Building</li>
                <li><span><%- include('partials/icon', { name: 'check' }) %></span>Performance Tracking</li>
              </ul>
            </div>

          <% } else if (service.heroVisual === 'ai-search') { %>
            <div class="viz-ai">
              <span class="viz-ai-head">AI Search Results <em>✦</em></span>
              <div class="ai-result is-main">
                <span class="ai-dot ok"><%- include('partials/icon', { name: 'check' }) %></span>
                <div><strong>Your Brand</strong><small>Trusted source · Cited by AI</small></div>
              </div>
              <div class="ai-result"><span class="ai-dot"></span><div><strong>Brand B</strong><small>AI mentioned</small></div></div>
              <div class="ai-result"><span class="ai-dot"></span><div><strong>Brand C</strong><small>AI mentioned</small></div></div>
              <ul class="ai-engines">
                <li>Google AI</li><li>ChatGPT</li><li>Gemini</li><li>Perplexity</li>
              </ul>
            </div>

          <% } else { %>
            <span class="svc-hero-mark" style="--c:<%= service.color %>"><%- include('partials/icon', { name: service.icon }) %></span>
            <div class="viz-card viz-traffic">
              <span class="viz-dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <div class="viz-head"><span>Organic Traffic</span><strong class="up">▲ +178%</strong></div>
              <svg viewBox="0 0 320 110" preserveAspectRatio="none" class="viz-chart">
                <defs>
                  <linearGradient id="vg" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#16b981" stop-opacity="0.30"/>
                    <stop offset="100%" stop-color="#16b981" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0,96 C42,92 58,72 92,74 C128,76 144,52 184,52 C220,52 250,30 286,22 C302,18 312,13 320,8 L320,110 L0,110 Z" fill="url(#vg)"/>
                <path d="M0,96 C42,92 58,72 92,74 C128,76 144,52 184,52 C220,52 250,30 286,22 C302,18 312,13 320,8"
                      fill="none" stroke="#16b981" stroke-width="2.5" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="viz-card viz-da">
              <span class="viz-da-label">Domain Authority</span>
              <div class="viz-gauge"><span>DA</span><strong>62</strong></div>
              <span class="viz-da-up up">▲ growing</span>
            </div>
          <% } %>
        </div>
      </div>
    </section>

    <% if (service.sections && service.sections.length) { %>
      <%# ===================== SECTION-DRIVEN RENDER ===================== %>
      <% var PALETTE = ['#3aa0ff','#16b981','#7c5cff','#ffb13c','#ff6b6b','#2fd0e8'];
         function blockColor(block, it, i){ return block.colorful ? PALETTE[i % PALETTE.length] : (it.color || service.color); } %>
      <% service.sections.forEach(function(block){ %>

        <% if (block.type === 'features') { %>
          <section class="section<%= block.alt ? ' section-alt' : '' %>"<% if (block.id) { %> id="<%= block.id %>"<% } %>>
            <div class="container">
              <h2 class="section-title"><%= block.title %> <% if (block.titleAccent) { %><span class="tx-accent"><%= block.titleAccent %></span> <% } %><%= block.titleAfter || '' %></h2>
              <% if (block.sub) { %><p class="section-sub"><%= block.sub %></p><% } %>
              <div class="feature-grid <%= block.layout === 'row' ? 'rows' : ((block.items.length >= 6) ? 'six' : 'five') %>">
                <% block.items.forEach(function(it, i){ %>
                  <article class="feature-card<%= block.layout === 'row' ? ' row' : '' %>" style="--c:<%= blockColor(block, it, i) %>">
                    <span class="feature-icon"><%- include('partials/icon', { name: it.icon || 'check' }) %></span>
                    <div class="feature-body">
                      <h3><%= it.title %></h3>
                      <p><%= it.text %></p>
                    </div>
                  </article>
                <% }); %>
              </div>
            </div>
          </section>

        <% } else if (block.type === 'flow') { %>
          <section class="section<%= block.alt ? ' section-alt' : '' %>"<% if (block.id) { %> id="<%= block.id %>"<% } %>>
            <div class="container">
              <h2 class="section-title"><%= block.title %> <% if (block.titleAccent) { %><span class="tx-accent"><%= block.titleAccent %></span> <% } %><%= block.titleAfter || '' %></h2>
              <% if (block.sub) { %><p class="section-sub"><%= block.sub %></p><% } %>
              <div class="flow-grid" style="grid-template-columns:repeat(<%= block.items.length %>,1fr)">
                <% block.items.forEach(function(it, i){ %>
                  <article class="flow-card" style="--c:<%= blockColor(block, it, i) %>">
                    <span class="flow-ico"><%- include('partials/icon', { name: it.icon || 'check' }) %><% if (block.numbered) { %><b class="flow-num"><%= i + 1 %></b><% } %></span>
                    <h3><%= it.title %></h3>
                    <p><%= it.text %></p>
                  </article>
                <% }); %>
              </div>
            </div>
          </section>

        <% } else if (block.type === 'cards') { %>
          <section class="section<%= block.alt ? ' section-alt' : '' %>"<% if (block.id) { %> id="<%= block.id %>"<% } %>>
            <div class="container">
              <h2 class="section-title"><%= block.title %></h2>
              <% if (block.sub) { %><p class="section-sub"><%= block.sub %></p><% } %>
              <div class="card-grid<%= block.compact ? ' compact' : '' %>"<% if (block.cols) { %> style="grid-template-columns:repeat(<%= block.cols %>,1fr)"<% } %>>
                <% block.items.forEach(function(it, i){ %>
                  <article class="service-card" style="--c:<%= blockColor(block, it, i) %>">
                    <span class="service-icon"><%- include('partials/icon', { name: it.icon || 'check' }) %></span>
                    <div class="service-body">
                      <h3><%= it.title %></h3>
                      <p><%= it.text %></p>
                    </div>
                  </article>
                <% }); %>
              </div>
            </div>
          </section>

        <% } else if (block.type === 'split') { %>
          <section class="section<%= block.alt ? ' section-alt' : '' %>"<% if (block.id) { %> id="<%= block.id %>"<% } %>>
            <div class="container split-grid">
              <% [block.left, block.right].forEach(function(side){ %>
                <div class="split-col">
                  <h2 class="block-title"><%= side.title %> <% if (side.titleAccent) { %><span class="tx-accent"><%= side.titleAccent %></span><% } %></h2>
                  <% if (side.sub) { %><p class="block-text"><%= side.sub %></p><% } %>
                  <% if (side.bullets && side.bullets.length) { %>
                    <div class="<%= side.image ? 'choose-row' : '' %>">
                      <ul class="check-list">
                        <% side.bullets.forEach(function(b){ %><li><span class="ck">✓</span><%= b %></li><% }); %>
                      </ul>
                      <% if (side.image) { %><div class="split-image"><img src="<%= side.image %>" alt="<%= side.title %>" loading="lazy" /></div><% } %>
                    </div>
                  <% } else if (side.items && side.items.length) { %>
                    <ul class="industry-grid">
                      <% side.items.forEach(function(it){ %>
                        <li class="industry-tile"><span class="industry-tile-ico" style="--c:<%= service.color %>"><%- include('partials/icon', { name: it.icon || 'check' }) %></span><span><%= it.label %></span></li>
                      <% }); %>
                    </ul>
                  <% } else if (side.testimonials && side.testimonials.length) { %>
                    <div class="split-tms">
                      <% side.testimonials.forEach(function(t){ %>
                        <figure class="tm-card">
                          <div class="rb-stars">★★★★★</div>
                          <blockquote>“<%= t.quote %>”</blockquote>
                          <figcaption><strong><%= t.author %></strong><span><%= t.role %></span></figcaption>
                        </figure>
                      <% }); %>
                    </div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </section>

        <% } else if (block.type === 'benefits') { %>
          <section class="section">
            <div class="container">
              <div class="benefits-band<%= block.testimonial ? ' with-quote' : '' %>">
                <% if (block.title) { %><div class="benefits-head"><h2><%= block.title %></h2></div><% } %>
                <div class="benefits-body">
                  <ul class="benefits-row<%= block.arrows ? ' arrows' : '' %>">
                    <% block.items.forEach(function(it){ %>
                      <li>
                        <span class="benefit-ico" style="--c:<%= it.color || service.color %>"><%- include('partials/icon', { name: it.icon || 'check' }) %></span>
                        <% if (it.value) { %><strong class="benefit-val"><%= it.value %></strong><% } %>
                        <span class="benefit-label"><%= it.label %></span>
                      </li>
                    <% }); %>
                  </ul>
                  <% if (block.testimonial) { %>
                    <figure class="benefits-quote">
                      <div class="rb-stars">★★★★★</div>
                      <blockquote>“<%= block.testimonial.quote %>”</blockquote>
                      <figcaption><strong><%= block.testimonial.author %></strong><span><%= block.testimonial.role %></span></figcaption>
                    </figure>
                  <% } %>
                </div>
              </div>
            </div>
          </section>

        <% } else if (block.type === 'tools') { %>
          <section class="section section-alt">
            <div class="container">
              <h2 class="section-title"><%= block.title %></h2>
              <% if (block.sub) { %><p class="section-sub"><%= block.sub %></p><% } %>
              <ul class="tools-row">
                <% block.items.forEach(function(t){ %><li class="tool-pill"><%= t %></li><% }); %>
              </ul>
            </div>
          </section>

        <% } else if (block.type === 'results') { %>
          <section class="section">
            <div class="container">
              <div class="results-band">
                <div class="results-band-top">
                  <h2><%= block.title %></h2>
                  <% if (block.sub) { %><p><%= block.sub %></p><% } %>
                </div>
                <div class="results-band-grid">
                  <div class="results-stats">
                    <% block.stats.forEach(function(s){ %>
                      <div class="rb-stat">
                        <span class="rb-ico" style="--c:<%= s[3] || service.color %>"><%- include('partials/icon', { name: s[2] || 'growth' }) %></span>
                        <strong><%= s[0] %></strong>
                        <span class="rb-label"><%= s[1] %></span>
                      </div>
                    <% }); %>
                  </div>
                  <% if (block.testimonial) { %>
                    <figure class="rb-quote">
                      <div class="rb-stars">★★★★★</div>
                      <blockquote>“<%= block.testimonial.quote %>”</blockquote>
                      <figcaption><strong><%= block.testimonial.author %></strong><span><%= block.testimonial.role %></span></figcaption>
                    </figure>
                  <% } %>
                </div>
              </div>
            </div>
          </section>

        <% } else if (block.type === 'testimonials') { %>
          <section class="section">
            <div class="container">
              <h2 class="section-title"><%= block.title %></h2>
              <% if (block.sub) { %><p class="section-sub"><%= block.sub %></p><% } %>
              <div class="tm-grid">
                <% block.items.forEach(function(t){ %>
                  <figure class="tm-card">
                    <div class="rb-stars">★★★★★</div>
                    <blockquote>“<%= t.quote %>”</blockquote>
                    <figcaption><strong><%= t.author %></strong><span><%= t.role %></span></figcaption>
                  </figure>
                <% }); %>
              </div>
            </div>
          </section>

        <% } else if (block.type === 'cta') { %>
          <section class="svc-cta">
            <div class="container">
              <div class="svc-cta-inner<%= block.variant === 'blue' ? ' blue' : '' %>">
                <div class="svc-cta-copy">
                  <h2><%= block.title %> <% if (block.titleAccent) { %><span><%= block.titleAccent %></span><% } %></h2>
                  <% if (block.text) { %><p><%= block.text %></p><% } %>
                  <div class="svc-cta-actions">
                    <a href="<%= (block.primary && block.primary.href) || '/#contact' %>" class="btn btn-light"><%= (block.primary && block.primary.label) || 'Get Free Audit' %></a>
                    <% if (block.secondary) { %><a href="<%= block.secondary.href || '/#contact' %>" class="btn btn-cta-ghost"><%= block.secondary.label %></a><% } %>
                  </div>
                </div>
                <% if (block.highlights && block.highlights.length) { %>
                  <ul class="svc-cta-highlights">
                    <% block.highlights.forEach(function(h){ %><li><span class="ck">✓</span><%= h %></li><% }); %>
                  </ul>
                <% } %>
              </div>
            </div>
          </section>

        <% } else if (block.type === 'faq') { %>
          <section class="section">
            <div class="container">
              <h2 class="section-title"><%= block.title || 'Frequently Asked Questions' %></h2>
              <div class="faq-grid">
                <% block.items.forEach(function(f){ %>
                  <article class="faq-card">
                    <span class="faq-q"><span class="faq-badge">?</span><%= f.q %></span>
                    <p class="faq-a"><%= f.a %></p>
                  </article>
                <% }); %>
              </div>
            </div>
          </section>
        <% } %>
      <% }); %>

    <% } else { %>
      <%# ===================== LEGACY FIELD RENDER ===================== %>
      <% if (service.why || service.strategy) { %>
      <section class="section">
        <div class="container">
          <div class="why-strategy<%= service.strategy ? ' two' : '' %>">
            <% if (service.why) { %>
            <div class="why-col">
              <h2 class="block-title"><%= service.why.title %></h2>
              <% if (service.why.intro) { %><p class="block-text"><%= service.why.intro %></p><% } %>
              <% if (service.why.lead) { %><p class="block-text"><strong><%= service.why.lead %></strong></p><% } %>
              <% if (service.why.bullets && service.why.bullets.length) { %>
                <ul class="check-list">
                  <% service.why.bullets.forEach(function(b){ %><li><span class="ck">✓</span><%= b %></li><% }); %>
                </ul>
              <% } else if (service.why.items && service.why.items.length) { %>
                <ul class="check-list">
                  <% service.why.items.forEach(function(it){ %><li><span class="ck">✓</span><strong><%= it.title %></strong> — <%= it.text %></li><% }); %>
                </ul>
              <% } %>
              <% if (service.why.outro) { %><p class="block-text muted"><%= service.why.outro %></p><% } %>
            </div>
            <% } %>
            <% if (service.strategy) { %>
            <div class="strategy-col">
              <h2 class="block-title"><%= service.strategy.title %></h2>
              <% if (service.strategy.intro) { %><p class="block-text"><%= service.strategy.intro %></p><% } %>
              <div class="strategy-grid">
                <% service.strategy.items.forEach(function(it){ %>
                  <div class="strategy-item">
                    <span class="strategy-ico" style="--c:<%= service.color %>"><%- include('partials/icon', { name: it.icon || 'check' }) %></span>
                    <div><strong><%= it.title %></strong><p><%= it.text %></p></div>
                  </div>
                <% }); %>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </section>
      <% } %>

      <% if (service.different && service.different.items) { %>
      <section class="section section-alt">
        <div class="container">
          <h2 class="section-title"><%= service.different.title %></h2>
          <% if (service.different.intro) { %><p class="section-sub"><%= service.different.intro %></p><% } %>
          <div class="feature-grid six">
            <% service.different.items.forEach(function(it){ %>
              <article class="feature-card" style="--c:<%= service.color %>">
                <span class="feature-icon"><%- include('partials/icon', { name: it.icon || 'check' }) %></span>
                <h3><%= it.title %></h3>
                <p><%= it.text %></p>
              </article>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>

      <% if (service.offerings && service.offerings.items) { %>
      <section class="section<%= service.different ? '' : ' section-alt' %>" id="offerings">
        <div class="container">
          <h2 class="section-title"><%= service.offerings.title %></h2>
          <% if (service.offerings.sub) { %><p class="section-sub"><%= service.offerings.sub %></p><% } %>
          <div class="card-grid">
            <% service.offerings.items.forEach(function(it){ %>
              <article class="service-card" style="--c:<%= service.color %>">
                <span class="service-icon"><%- include('partials/icon', { name: it.icon || 'check' }) %></span>
                <div class="service-body">
                  <h3><%= it.title %></h3>
                  <p><%= it.text %></p>
                </div>
              </article>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>

      <% if (service.process && service.process.items) { %>
      <section class="section">
        <div class="container">
          <h2 class="section-title"><%= service.process.title %></h2>
          <% if (service.process.sub) { %><p class="section-sub"><%= service.process.sub %></p><% } %>
          <ol class="proc-flow">
            <% service.process.items.forEach(function(it, i){ %>
              <li class="proc-step" style="--c:<%= service.color %>">
                <span class="proc-num"><%= i + 1 %></span>
                <h4><%= it.title %></h4>
                <p><%= it.text %></p>
              </li>
            <% }); %>
          </ol>
        </div>
      </section>
      <% } %>

      <% if (service.guide && service.guide.items) { %>
      <section class="section section-alt">
        <div class="container">
          <div class="guide-panel">
            <h2 class="section-title"><%= service.guide.title %></h2>
            <% if (service.guide.sub) { %><p class="section-sub"><%= service.guide.sub %></p><% } %>
            <div class="guide-grid">
              <% service.guide.items.forEach(function(it, i){ %>
                <article class="guide-card" style="--c:<%= service.color %>">
                  <span class="guide-num"><%= String(i + 1).padStart(2, '0') %></span>
                  <h4><%= it.title %></h4>
                  <p><%= it.text %></p>
                </article>
              <% }); %>
            </div>
          </div>
        </div>
      </section>
      <% } %>

      <% if (service.industries && service.industries.items) { %>
      <section class="section">
        <div class="container">
          <h2 class="section-title"><%= service.industries.title %></h2>
          <% if (service.industries.sub) { %><p class="section-sub"><%= service.industries.sub %></p><% } %>
          <ul class="industries-row">
            <% service.industries.items.forEach(function(it){ %>
              <li class="industry"><span class="industry-ico" style="--c:<%= service.color %>"><%- include('partials/icon', { name: it.icon || 'check' }) %></span><span><%= it.label %></span></li>
            <% }); %>
          </ul>
          <% if (service.industries.outro) { %><p class="section-sub" style="margin-top:28px"><%= service.industries.outro %></p><% } %>
        </div>
      </section>
      <% } %>

      <% if (service.whyChoose) { %>
      <section class="section section-alt">
        <div class="container narrow-prose">
          <h2 class="section-title"><%= service.whyChoose.title %></h2>
          <% (service.whyChoose.paragraphs || []).forEach(function(p){ %><p class="prose-p"><%= p %></p><% }); %>
        </div>
      </section>
      <% } %>

      <section class="svc-cta">
        <div class="container">
          <div class="svc-cta-inner">
            <div class="svc-cta-copy">
              <h2>Ready to Grow Your Rankings?</h2>
              <p>Partner with <%= site.brand %> to build a strategy that improves your rankings, visibility, and long-term growth.</p>
              <div class="svc-cta-actions">
                <a href="/#contact" class="btn btn-light">Get Free Audit</a>
                <a href="/#contact" class="btn btn-cta-ghost">Contact Us Now</a>
              </div>
            </div>
            <% var stats = service.stats && service.stats.length ? service.stats : [['500+','Happy Clients'],['10K+','Backlinks Built'],['98%','Client Satisfaction']]; %>
            <div class="svc-cta-stats">
              <% stats.forEach(function(s){ %>
                <div class="svc-stat"><strong><%= s[0] %></strong><span><%= s[1] %></span></div>
              <% }); %>
            </div>
          </div>
        </div>
      </section>

      <% if (service.faqs && service.faqs.items) { %>
      <section class="section">
        <div class="container">
          <h2 class="section-title"><%= service.faqs.title || 'Frequently Asked Questions' %></h2>
          <div class="faq-grid">
            <% service.faqs.items.forEach(function(f){ %>
              <article class="faq-card">
                <span class="faq-q"><span class="faq-badge">?</span><%= f.q %></span>
                <p class="faq-a"><%= f.a %></p>
              </article>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>
    <% } %>

    <!-- ============ OTHER SERVICES ============ -->
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-title" style="margin-bottom:8px">Explore other services</h2>
        <div class="card-grid" style="margin-top:40px">
          <% services.filter(function(s){ return s.slug !== service.slug; }).forEach(function(s){ %>
            <article class="service-card" style="--c:<%= s.color %>">
              <span class="service-icon"><%- include('partials/icon', { name: s.icon }) %></span>
              <div class="service-body">
                <h3><%= s.name %></h3>
                <p><%= s.summary %></p>
                <a href="/services/<%= s.slug %>" class="learn-more">Learn More →</a>
              </div>
            </article>
          <% }); %>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
  <%- include('partials/tawk') %>
</body>
</html>
