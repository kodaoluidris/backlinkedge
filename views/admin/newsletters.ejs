<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/admin-head') %>
  <title>Newsletter Subscribers — Admin</title>
</head>
<body class="admin-body">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { active, adminEmail }) %>

    <main class="admin-main">
      <header class="admin-topbar">
        <div>
          <h1>Newsletter Subscribers</h1>
          <p><%= subscribers.length %> subscriber<%= subscribers.length === 1 ? '' : 's' %> collected.</p>
        </div>
        <div style="display:flex; gap:10px; align-items:center;">
          <input type="search" id="news-search" class="admin-search" placeholder="Search email…" />
          <a href="/admin/newsletters/export" class="btn btn-outline btn-sm">Export CSV</a>
        </div>
      </header>

      <% if (flash === 'deleted') { %>
        <div class="alert alert-warn">Subscriber removed.</div>
      <% } %>

      <section class="panel">
        <% if (!subscribers.length) { %>
          <p class="empty">No subscribers yet. When visitors sign up via the footer newsletter form, they’ll appear here.</p>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Email</th>
                  <th>Source</th>
                  <th>Status</th>
                  <th>Subscribed</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% subscribers.forEach(function (s, i) { %>
                  <tr>
                    <td class="muted"><%= i + 1 %></td>
                    <td><strong><%= s.email %></strong></td>
                    <td class="muted"><%= s.source || 'footer' %></td>
                    <td><span class="status status-active"><%= s.status || 'subscribed' %></span></td>
                    <td class="muted"><%= formatDate(s.created_at) %></td>
                    <td>
                      <form method="POST" action="/admin/newsletters/<%= s.id %>/delete" onsubmit="return confirm('Remove this subscriber?');">
                        <button type="submit" class="btn btn-outline btn-sm">Remove</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <script>
    const input = document.getElementById('news-search');
    if (input) {
      input.addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.data-table tbody tr').forEach(function (row) {
          row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
      });
    }
  </script>
</body>
</html>
