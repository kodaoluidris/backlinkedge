<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/admin-head') %>
  <title><%= post && post.id ? 'Edit' : 'New' %> Post — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
</head>
<body class="admin-body">
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { active, adminEmail }) %>

    <main class="admin-main">
      <%
        const isEdit = post && post.id;
        const action = isEdit ? ('/admin/blogs/' + post.id) : '/admin/blogs';
        const v = post || {};
      %>
      <header class="admin-topbar">
        <div>
          <h1><%= isEdit ? 'Edit Post' : 'New Post' %></h1>
          <p><%= isEdit ? 'Update this article.' : 'Write and publish a new article.' %></p>
        </div>
        <a href="/admin/blogs" class="btn btn-outline btn-sm">← Back to posts</a>
      </header>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="<%= action %>" enctype="multipart/form-data" class="panel blog-form">
        <div class="form-row">
          <label class="form-field">
            <span>Title <em>*</em></span>
            <input type="text" name="title" value="<%= v.title || '' %>" placeholder="e.g. 10 White-Hat Backlink Strategies That Work" required />
          </label>
        </div>

        <div class="form-row two">
          <label class="form-field">
            <span>Author</span>
            <input type="text" name="author" value="<%= v.author || 'Backlinkedge Team' %>" placeholder="Author name" />
          </label>
          <label class="form-field">
            <span>Status</span>
            <select name="status">
              <option value="published" <%= v.status !== 'draft' ? 'selected' : '' %>>Published</option>
              <option value="draft" <%= v.status === 'draft' ? 'selected' : '' %>>Draft</option>
            </select>
          </label>
        </div>

        <div class="form-row">
          <label class="form-field">
            <span>Excerpt <small>(short summary shown on cards)</small></span>
            <textarea name="excerpt" rows="2" placeholder="One or two sentences summarizing the post…"><%= v.excerpt || '' %></textarea>
          </label>
        </div>

        <div class="form-row">
          <span class="form-label">Featured media <small>(image or video)</small></span>
          <% const pm = v.image ? resolveMedia(v.image, v.media_type) : null; %>
          <% if (pm) { %>
            <div class="image-preview">
              <% if (pm.kind === 'embed') { %>
                <div class="post-embed"><iframe src="<%= pm.src %>" frameborder="0" allowfullscreen></iframe></div>
              <% } else if (pm.kind === 'video') { %>
                <video src="<%= pm.src %>" controls preload="metadata"></video>
              <% } else { %>
                <img src="<%= pm.src %>" alt="Current media" />
              <% } %>
              <small>Current <%= pm.kind === 'image' ? 'image' : 'video' %> — upload a new file or paste a new URL to replace it.</small>
            </div>
          <% } %>
          <label class="file-drop">
            <input type="file" name="image" accept="image/*,video/*" />
            <span>📷 Click to upload an image or 🎬 video (max 100MB · MP4, WebM, MOV)</span>
          </label>
          <label class="form-field" style="margin-top:10px">
            <span>…or paste an image / video URL <small>(direct file, YouTube, or Vimeo)</small></span>
            <input type="url" name="image_url" placeholder="https://youtube.com/watch?v=… or https://example.com/video.mp4" />
          </label>
        </div>

        <div class="form-row">
          <span class="form-label">Content <em>*</em></span>
          <!-- Rich text editor (Quill). Writes HTML into the hidden textarea on submit. -->
          <div id="editor-wrap">
            <div id="editor-toolbar">
              <span class="ql-formats">
                <select class="ql-header"><option value="2"></option><option value="3"></option><option selected></option></select>
              </span>
              <span class="ql-formats">
                <button class="ql-bold"></button>
                <button class="ql-italic"></button>
                <button class="ql-underline"></button>
                <button class="ql-strike"></button>
              </span>
              <span class="ql-formats">
                <button class="ql-list" value="ordered"></button>
                <button class="ql-list" value="bullet"></button>
                <button class="ql-blockquote"></button>
                <button class="ql-code-block"></button>
              </span>
              <span class="ql-formats">
                <button class="ql-link"></button>
                <button class="ql-image"></button>
              </span>
              <span class="ql-formats">
                <button class="ql-clean"></button>
              </span>
            </div>
            <div id="editor"><%- v.content || '' %></div>
          </div>
          <textarea name="content" id="content-input" hidden><%= v.content || '' %></textarea>
          <small class="hint">Use the toolbar to style your content — headings, bold, lists, links, quotes and more.</small>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= isEdit ? 'Save Changes' : 'Publish Post' %></button>
          <a href="/admin/blogs" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </main>
  </div>

  <script>
    // Show selected filename in the drop label
    document.querySelector('input[name="image"]').addEventListener('change', function () {
      const label = this.parentElement.querySelector('span');
      if (this.files && this.files[0]) {
        const f = this.files[0];
        const icon = f.type.startsWith('video/') ? '🎬 ' : '📷 ';
        label.textContent = icon + f.name;
      }
    });

    // Rich text editor (Quill)
    (function () {
      const input = document.getElementById('content-input');
      const editorEl = document.getElementById('editor');
      const wrap = document.getElementById('editor-wrap');
      if (!editorEl || !input) return;

      // Fallback: if the Quill library didn't load (e.g. offline/CDN blocked),
      // reveal the plain textarea so content can still be written.
      if (!window.Quill) {
        if (wrap) wrap.style.display = 'none';
        input.hidden = false;
        input.rows = 16;
        return;
      }

      const quill = new Quill('#editor', {
        theme: 'snow',
        placeholder: 'Write your article here…',
        modules: { toolbar: '#editor-toolbar' }
      });

      // Keep the hidden textarea in sync so it posts with the form.
      function sync() {
        const html = quill.getText().trim().length ? quill.root.innerHTML : '';
        input.value = html;
      }
      quill.on('text-change', sync);
      sync();

      const form = input.closest('form');
      form.addEventListener('submit', function (e) {
        sync();
        if (!quill.getText().trim().length) {
          e.preventDefault();
          alert('Please add some content before saving.');
        }
      });
    })();
  </script>
</body>
</html>
