# ───────────────────────────────────────────────
#  Backlinkedge SEO — environment configuration
#  Copy this file to ".env" and fill in real values.
# ───────────────────────────────────────────────

# App
PORT=4000
# Public base URL (used to build Stripe success/cancel redirect URLs)
BASE_URL=http://localhost:4000

# Stripe — get these from https://dashboard.stripe.com/test/apikeys
# Use the TEST keys (they start with sk_test_ / pk_test_) while developing.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret — from `stripe listen` or the dashboard webhook.
# Starts with whsec_
STRIPE_WEBHOOK_SECRET=

# Admin login (change these!)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Secret used to sign admin session cookies (use a long random string)
SESSION_SECRET=

# Tawk.to live chat — from your widget's Direct Chat Link / embed code:
# https://embed.tawk.to/<PROPERTY_ID>/<WIDGET_ID>
# Leave blank to disable the chat widget.
TAWKTO_PROPERTY_ID=
TAWKTO_WIDGET_ID=default
